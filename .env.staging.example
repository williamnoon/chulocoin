# Staging Environment Configuration for ChuloBots
# Copy this to .env.staging and fill in your values

# Docker Configuration
DOCKER_USERNAME=willnoon
ENVIRONMENT=staging
VERSION=v1.0.0

# Database
POSTGRES_USER=chulobots
POSTGRES_PASSWORD=<secure-password>
POSTGRES_DB=chulobots_staging
POSTGRES_PORT=5432
DATABASE_URL=postgresql://chulobots:<password>@postgres:5432/chulobots_staging

# Redis
REDIS_PASSWORD=<secure-password>
REDIS_PORT=6379
REDIS_URL=redis://:<password>@redis:6379

# Backend
NODE_ENV=production
JWT_SECRET=<secure-jwt-secret>
ENCRYPTION_KEY=<32-byte-hex-key>
BACKEND_PORT=3001

# Blockchain - Arbitrum Sepolia Testnet
ARBITRUM_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
ARBISCAN_API_KEY=<your-arbiscan-api-key>

# Contract Addresses (update after deployment)
CHULO_TOKEN_ADDRESS=0x...
SIGNAL_REGISTRY_ADDRESS=0x...
TIER_NFT_ADDRESS=0x...
VALIDATOR_STAKING_ADDRESS=0x...

# Frontend
WEBAPP_PORT=80
LANDING_PORT=3000
VITE_API_URL=https://api-staging.chulobots.com
NEXT_PUBLIC_API_URL=https://api-staging.chulobots.com
NEXT_PUBLIC_APP_URL=https://app-staging.chulobots.com
