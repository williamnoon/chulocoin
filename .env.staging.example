# ============================================
# STAGING ENVIRONMENT CONFIGURATION
# ============================================
# This file contains ALL environment variables needed across all services
# Copy to .env and fill in your actual values
#
# NEVER commit the actual .env file to git!
# ============================================

# ============================================
# BACKEND SERVICE VARIABLES (Railway)
# ============================================

# Environment
NODE_ENV=staging
PORT=3000

# Database (provided by Railway PostgreSQL service)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:password@postgres.railway.internal:5432/railway

# Redis (provided by Railway Redis service)
# Format: redis://host:port
REDIS_URL=redis://redis.railway.internal:6379

# JWT Authentication
# Generate with: openssl rand -hex 32
JWT_SECRET=your-secure-random-jwt-secret-here-use-openssl-to-generate
JWT_EXPIRATION=7d

# CORS Configuration
# Update with your actual Vercel URLs after deployment
ALLOWED_ORIGINS=https://your-landing-xyz.vercel.app,https://your-webapp-abc.vercel.app,https://staging.yourdomain.com

# Rate Limiting
RATE_LIMIT_WINDOW=15m
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# SMART CONTRACT ADDRESSES
# ============================================
# These come from contracts/deployments/sepolia.json after deployment
# Deploy contracts first, then copy addresses here

CHULO_ADDRESS=0x0000000000000000000000000000000000000000
SIGNAL_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
VALIDATOR_STAKING_ADDRESS=0x0000000000000000000000000000000000000000
TIER_NFT_ADDRESS=0x0000000000000000000000000000000000000000

# ============================================
# BLOCKCHAIN CONFIGURATION
# ============================================

# Arbitrum Sepolia RPC
ARBITRUM_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc
# Alternative: https://arbitrum-sepolia.publicnode.com

# Oracle Contract (ChainlinkPriceOracle address)
ORACLE_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Chainlink Price Feeds on Arbitrum Sepolia
# Official Chainlink Data Feeds for Arbitrum Sepolia testnet
CHAINLINK_PRICE_FEED_BTC=0x56a43EB56Da12C0dc1D972ACb089c06a5dEF8e69
CHAINLINK_PRICE_FEED_ETH=0xd30e2101a97dcbAeBCBC04F14C3f624E67A35165
CHAINLINK_PRICE_FEED_SOL=0x0000000000000000000000000000000000000000

# ============================================
# EXCHANGE API KEYS (TESTNET)
# ============================================
# Use testnet/sandbox credentials only!

# Hyperliquid Testnet
HYPERLIQUID_API_KEY=your-hyperliquid-testnet-api-key
HYPERLIQUID_API_SECRET=your-hyperliquid-testnet-api-secret
HYPERLIQUID_TESTNET=true

# Binance Testnet
# Get from: https://testnet.binance.vision/
BINANCE_API_KEY=your-binance-testnet-api-key
BINANCE_API_SECRET=your-binance-testnet-api-secret
BINANCE_TESTNET=true

# Coinbase Sandbox
# Get from: https://public.sandbox.pro.coinbase.com
COINBASE_API_KEY=your-coinbase-sandbox-api-key
COINBASE_API_SECRET=your-coinbase-sandbox-api-secret
COINBASE_API_PASSPHRASE=your-coinbase-sandbox-passphrase
COINBASE_SANDBOX=true

# ============================================
# SECURITY
# ============================================

# API Key Encryption (32-byte hex string)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-32-byte-encryption-key-in-hex-format-64-characters

# Session Secret
# Generate with: openssl rand -hex 32
SESSION_SECRET=your-session-secret-here-use-openssl-to-generate

# ============================================
# FRONTEND VARIABLES (Vercel)
# ============================================

# API Endpoints
# Update these after deploying backend to Railway
VITE_API_URL=https://your-backend.railway.app
VITE_WS_URL=wss://your-backend.railway.app

# Smart Contract Addresses (same as backend)
VITE_CHULO_ADDRESS=0x0000000000000000000000000000000000000000
VITE_SIGNAL_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
VITE_VALIDATOR_STAKING_ADDRESS=0x0000000000000000000000000000000000000000

# Blockchain Configuration
VITE_CHAIN_ID=421614
VITE_CHAIN_NAME=Arbitrum Sepolia
VITE_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
VITE_BLOCK_EXPLORER=https://sepolia.arbiscan.io

# Feature Flags
VITE_ENABLE_TESTNET_WARNING=true
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_SENTRY=false

# ============================================
# LANDING PAGE (Next.js on Vercel)
# ============================================

NEXT_PUBLIC_API_URL=https://your-backend.railway.app
NEXT_PUBLIC_WEBAPP_URL=https://your-webapp-abc.vercel.app
NEXT_PUBLIC_CHAIN_ID=421614

# ============================================
# CONTRACT DEPLOYMENT VARIABLES
# ============================================
# Used in contracts/.env for deployment

# Deployer Private Key
# MUST have testnet ETH on Arbitrum Sepolia
# Get testnet ETH: https://faucet.quicknode.com/arbitrum/sepolia
PRIVATE_KEY=your_private_key_for_deployment_with_testnet_eth

# Arbitrum Sepolia RPC URL
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# Arbiscan API Key for Contract Verification
# Get from: https://arbiscan.io/myapikey
ARBISCAN_API_KEY=your_arbiscan_api_key_for_verification

# Gas Reporting (Optional)
REPORT_GAS=false
COINMARKETCAP_API_KEY=your_coinmarketcap_api_key_optional

# ============================================
# CLI CONFIGURATION
# ============================================
# For local testing with staging environment

CLI_WALLET_ADDRESS=0x0000000000000000000000000000000000000000
CLI_PRIVATE_KEY=your_cli_wallet_private_key
CLI_BACKEND_URL=https://your-backend.railway.app
CLI_WS_URL=wss://your-backend.railway.app

# ============================================
# MONITORING & LOGGING (Optional)
# ============================================

# Sentry Error Tracking
SENTRY_DSN=your-sentry-dsn-here
SENTRY_ENVIRONMENT=staging

# LogRocket Session Replay
LOGROCKET_APP_ID=your-logrocket-app-id

# DataDog
DATADOG_API_KEY=your-datadog-api-key
DATADOG_ENVIRONMENT=staging

# ============================================
# DEVELOPMENT HELPERS
# ============================================

# Enable detailed logging
DEBUG=chulobots:*
LOG_LEVEL=debug

# Enable SQL query logging
DATABASE_LOGGING=true

# Enable WebSocket debugging
WS_DEBUG=true

# ============================================
# DEPLOYMENT SECRETS (GitHub Actions)
# ============================================
# These should be set in GitHub Secrets, not in .env

# GitHub Secrets to configure:
# - RAILWAY_TOKEN
# - VERCEL_TOKEN
# - VERCEL_ORG_ID
# - VERCEL_PROJECT_ID_LANDING
# - VERCEL_PROJECT_ID_WEBAPP
# - DEPLOYER_PRIVATE_KEY_TESTNET
# - ARBISCAN_API_KEY

# ============================================
# NOTES
# ============================================
#
# 1. DEPLOYMENT ORDER:
#    - Deploy contracts first
#    - Update contract addresses in this file
#    - Deploy backend with contract addresses
#    - Deploy frontend with backend URL + contract addresses
#
# 2. NEVER USE MAINNET KEYS IN STAGING
#    - Always use testnet/sandbox credentials
#    - Never commit real private keys
#
# 3. GENERATE SECURE SECRETS:
#    openssl rand -hex 32
#
# 4. GET TESTNET ETH:
#    https://faucet.quicknode.com/arbitrum/sepolia
#    https://bridge.arbitrum.io/?destinationChain=arbitrum-sepolia
#
# 5. VERIFY DEPLOYMENTS:
#    - Backend health: https://your-backend.railway.app/health
#    - Contracts: https://sepolia.arbiscan.io/address/0x...
#    - Frontend: https://your-webapp.vercel.app
#
# ============================================
