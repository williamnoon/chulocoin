# ChuloBots Production Environment Variables
# Copy this file to .env.production and fill in your values

# Database
POSTGRES_PASSWORD=your_secure_postgres_password_here

# Redis
REDIS_PASSWORD=your_secure_redis_password_here

# Backend API
JWT_SECRET=your_secure_jwt_secret_here_min_32_chars
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
CORS_ORIGIN=https://app.yourdomain.com,https://yourdomain.com

# Smart Contract Addresses (from deployment)
CHULO_TOKEN_ADDRESS=0x...
SIGNAL_REGISTRY_ADDRESS=0x...
VALIDATOR_STAKING_ADDRESS=0x...

# Bot Executor (Trading)
HYPERLIQUID_PRIVATE_KEY=0x...
HYPERLIQUID_VAULT_ADDRESS=0x...
MAX_POSITION_SIZE=1000
DAILY_LOSS_LIMIT=100

# Frontend URLs
API_URL=https://api.yourdomain.com
APP_URL=https://app.yourdomain.com
WS_URL=wss://api.yourdomain.com
CHAIN_ID=42161

# Validator (optional - uncomment CLI service in docker-compose)
# VALIDATOR_PRIVATE_KEY=0x...
