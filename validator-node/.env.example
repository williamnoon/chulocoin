# ============================================
# ChuloBots Validator Node Configuration
# ============================================

# VALIDATOR IDENTITY
# ============================================
# Your validator wallet address (must have staked CHULO)
VALIDATOR_WALLET=0x742d35Cc6634C0532925a3b844Bc9e7595f3a9f

# Your wallet private key (KEEP SECRET!)
VALIDATOR_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Your validator display name
VALIDATOR_NAME=ChuloBots Validator #1

# Stake tier (1, 2, or 3)
STAKE_TIER=2

# ============================================
# CHULOBOTS API
# ============================================
# ChuloBots API endpoint
CHULOBOTS_API_URL=https://api.chulobots.com

# WebSocket URL for receiving signals
CHULOBOTS_WS_URL=wss://api.chulobots.com

# ============================================
# BLOCKCHAIN CONFIGURATION
# ============================================
# Arbitrum RPC URL
# Free: https://arb1.arbitrum.io/rpc
# Alchemy: https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
# Infura: https://arbitrum-mainnet.infura.io/v3/YOUR_KEY
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc

# Chainlink RPC for price feeds (recommend Alchemy)
CHAINLINK_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# Chain ID (42161 for Arbitrum One, 421614 for Sepolia)
CHAIN_ID=42161

# ============================================
# SMART CONTRACT ADDRESSES
# ============================================
# Get from: https://chulobots.com/contracts
CHULO_CONTRACT=0x...
STAKING_CONTRACT=0x...
ORACLE_CONTRACT=0x...

# ============================================
# DATABASE
# ============================================
# PostgreSQL connection string
DATABASE_URL=postgresql://validator:changeme@localhost:5432/validator

# ============================================
# PERFORMANCE TUNING
# ============================================
# Max concurrent backtests (based on CPU cores)
# 2 CPU cores → 3-4 concurrent
# 4 CPU cores → 5-8 concurrent
MAX_CONCURRENT_BACKTESTS=5

# Backtest timeout (seconds)
BACKTEST_TIMEOUT=60

# ============================================
# DASHBOARD
# ============================================
# Dashboard HTTP port
DASHBOARD_PORT=3001

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# ============================================
# VALIDATION PARAMETERS
# ============================================
# Minimum Sharpe ratio to approve signal
MIN_SHARPE=1.5

# Minimum win rate to approve signal (0.0 - 1.0)
MIN_WIN_RATE=0.55

# Maximum drawdown to approve signal (0.0 - 1.0)
MAX_DRAWDOWN=0.25

# Minimum quality score to approve signal (0-100)
MIN_QUALITY_SCORE=70

# Price tolerance for oracle verification (0.005 = 0.5%)
PRICE_TOLERANCE=0.005

# Consensus threshold (0.66 = 66% agreement required)
CONSENSUS_THRESHOLD=0.66
