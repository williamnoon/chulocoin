# Environment
NODE_ENV=staging

# Server
PORT=3000

# Database
DATABASE_URL=postgresql://user:password@host:5432/chulobots_staging

# Redis
REDIS_URL=redis://localhost:6379

# JWT & Authentication
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRATION=7d

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002

# Rate Limiting
RATE_LIMIT_WINDOW=15m
RATE_LIMIT_MAX_REQUESTS=100

# Contract Addresses (from deployment)
CHULO_ADDRESS=0x...
SIGNAL_REGISTRY_ADDRESS=0x...
VALIDATOR_STAKING_ADDRESS=0x...

# RPC
ARBITRUM_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc
ORACLE_CONTRACT_ADDRESS=0x...

# Chainlink Price Feeds
CHAINLINK_PRICE_FEED_BTC=0x...
CHAINLINK_PRICE_FEED_ETH=0x...
CHAINLINK_PRICE_FEED_SOL=0x...

# API Keys (Exchange Integrations)
HYPERLIQUID_API_KEY=your-api-key
BINANCE_API_KEY=your-api-key
BINANCE_API_SECRET=your-api-secret
COINBASE_API_KEY=your-api-key
COINBASE_API_SECRET=your-api-secret

# Encryption key for API keys (32-byte hex string)
ENCRYPTION_KEY=your-32-byte-encryption-key-here
