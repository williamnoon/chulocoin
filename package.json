{
  "name": "chulobots",
  "version": "0.1.0",
  "private": true,
  "description": "ChuloBots Decentralized Signal Validation Network",
  "workspaces": [
    "contracts",
    "backend",
    "bot-executor",
    "frontend/landing",
    "frontend/webapp",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "prettier": "^3.2.5",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "typescript": "^5.3.3"
  },
  "packageManager": "npm@10.2.5",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
