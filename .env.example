# Database
DATABASE_URL="postgresql://user:password@localhost:5432/chulobots"

# Redis
REDIS_URL="redis://localhost:6379"

# Blockchain
ARBITRUM_RPC="https://arb-goerli.g.alchemy.com/v2/YOUR_KEY"
PRIVATE_KEY="your-private-key-for-testnet"
ORACLE_CONTRACT_ADDRESS="0x..."

# Chainlink
CHAINLINK_PRICE_FEED_BTC="0x..."
CHAINLINK_PRICE_FEED_ETH="0x..."
CHAINLINK_PRICE_FEED_SOL="0x..."

# API Keys (Exchange Integrations)
HYPERLIQUID_API_KEY="your-api-key"
BINANCE_API_KEY="your-api-key"
BINANCE_API_SECRET="your-api-secret"
COINBASE_API_KEY="your-api-key"
