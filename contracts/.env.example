# Private key for deployment (DO NOT commit the actual .env file)
PRIVATE_KEY=your_private_key_here

# RPC URLs (used by both Hardhat and Foundry)
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
ARBITRUM_MAINNET_RPC=https://arb1.arbitrum.io/rpc

# Alternative RPC providers (optional)
# ALCHEMY_API_KEY=your_alchemy_key
# INFURA_API_KEY=your_infura_key

# Arbiscan API key for contract verification (Hardhat & Foundry)
ARBISCAN_API_KEY=your_arbiscan_api_key

# Optional: Gas reporting (Hardhat)
REPORT_GAS=false
COINMARKETCAP_API_KEY=your_coinmarketcap_api_key

# Optional: Foundry specific
# FOUNDRY_PROFILE=default
# FOUNDRY_FUZZ_RUNS=256
